                        "editorMode": "code",
                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "SELECT \n  ROUND(\n    AVG(actual_hours) / NULLIF(AVG(estimated_hours), 0), \n    2\n  ) AS effort_accuracy_ratio\nFROM sno_tasks \nWHERE status = 'done'\n  AND tags NOT LIKE '%maintenance%'\n  AND actual_hours IS NOT NULL \n  AND estimated_hours IS NOT NULL\n  AND estimated_hours > 0\n",
