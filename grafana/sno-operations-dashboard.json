      "panel-1": {
        "kind": "Panel",
        "spec": {
          "id": 1,
          "title": "Active Incidents by Observatory",
          "description": "",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "grafana-postgresql-datasource",
                      "version": "v0",
                      "datasource": {
                        "name": "afet67qw6aupsf"
                      },
                      "spec": {
                        "dataset": "dbhzmxgtopgnav",
                        "editorMode": "code",
                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "WITH tasks_enriched AS (\n  SELECT \n    sensor,\n    observatory_id,\n    priority,\n    CASE\n      WHEN priority = 'urgent' THEN 1\n      WHEN priority = 'high' THEN 2\n      ELSE 3  \n    END AS priority_number\n  FROM sno_tasks\n  WHERE status != 'done' AND tags NOT LIKE '%maintenance%'\n)\nSELECT \n  s.sensor,\n  s.name,\n  s.lat, \n  s.lon, \n  CASE \n    WHEN min(t.priority_number) = 1 THEN 'Urgent'\n    WHEN min(t.priority_number) = 2 THEN 'High'\n    WHEN min(t.priority_number) = 3 THEN 'Normal'\n    ELSE 'Healthy'\n  END as priority_status,\n  CASE \n    WHEN s.sensor IN (${selected_sensors:sqlstring}) THEN 10\n    ELSE 5\n  END AS marker_size,\n  CASE \n    WHEN s.sensor IN (${selected_sensors:sqlstring}) THEN s.sensor\n    ELSE ''\n  END AS label\nFROM sensors s\nLEFT JOIN tasks_enriched t ON s.sensor = t.sensor AND s.observatory_id = t.observatory_id\nGROUP BY s.sensor, s.name, s.lat, s.lon\n\n",
                        "sql": {
                          "columns": [
                            {
                              "parameters": [],
                              "type": "function"
                            }
                          ],
                          "groupBy": [
                            {
                              "property": {
                                "type": "string"
                              },
                              "type": "groupBy"
                            }
                          ],
                          "limit": 50
                        }
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
