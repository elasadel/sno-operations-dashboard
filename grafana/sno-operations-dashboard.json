                      "spec": {
                        "dataset": "dbhzmxgtopgnav",
                        "editorMode": "code",
                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "SELECT \n  COUNT(DISTINCT CASE WHEN t.tags NOT LIKE '%maintenance%' THEN s.sensor END) * 100.00 \n  / COUNT(DISTINCT s.sensor) AS unhealthy_pct\nFROM sensors s\nLEFT JOIN sno_tasks t ON s.sensor = t.sensor AND t.status != 'done'\n",
